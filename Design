import React, { useState, useRef } from 'react';
import Link from 'next/link';
import { Heart, Play, Pause, Share2, MessageCircle } from 'lucide-react';
import api from '../lib/api';
import { useAuth } from '../hooks/useAuth';

export default function SetCard({ set, onUpdate }) {
  const { user } = useAuth();
  const [playing, setPlaying] = useState(false);
  const [likes, setLikes] = useState(set.likes?.length || 0);
  const [liked, setLiked] = useState(set.likes?.includes(user?._id) || false);
  const audioRef = useRef(null);
  const [progress, setProgress] = useState(0);

  const togglePlay = () => {
    if (audioRef.current) {
      if (playing) {
        audioRef.current.pause();
      } else {
        audioRef.current.play();
        api.post(`/sets/${set._id}/play`).catch(console.error);
      }
      setPlaying(!playing);
    }
  };

  const handleLike = async () => {
    if (!user) return alert('Faça login para curtir');
    await api.post(`/sets/${set._id}/like`);
    const newLiked = !liked;
    setLiked(newLiked);
    setLikes(prev => newLiked ? prev + 1 : prev - 1);
  };

  const handleTimeUpdate = () => {
    if (audioRef.current) {
      const progress = (audioRef.current.currentTime / audioRef.current.duration) * 100;
      setProgress(progress || 0);
    }
  };

  return (
    <div className="bg-gray-900/80 backdrop-blur-sm rounded-xl overflow-hidden border border-gray-800 hover:border-green-800/50 transition-all duration-300 hover:shadow-[0_0_30px_rgba(34,197,94,0.15)] group">
      <div className="relative h-52 bg-gradient-to-br from-gray-800 to-black">
        {set.coverImage ? (
          <img src={set.coverImage} alt={set.title} className="w-full h-full object-cover" />
        ) : (
          <div className="w-full h-full flex items-center justify-center bg-gray-800">
            <span className="text-gray-600 text-6xl">🎵</span>
          </div>
        )}
        
        <div className="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>

        {set.userId?.isOfficial && (
          <span className="absolute top-3 right-3 bg-green-600 text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wider border border-green-400 shadow-lg">
            Oficial
          </span>
        )}

        <button
          onClick={togglePlay}
          className="absolute inset-0 flex items-center justify-center group/play"
        >
          <div className="w-16 h-16 bg-green-600/90 rounded-full flex items-center justify-center hover:scale-110 transition-transform duration-200 shadow-2xl shadow-green-600/50">
            {playing ? (
              <Pause size={28} className="text-white" />
            ) : (
              <Play size={28} className="text-white ml-1" />
            )}
          </div>
        </button>

        <div className="absolute bottom-0 left-0 right-0 h-1 bg-gray-700">
          <div 
            className="h-full bg-green-600 transition-all duration-300" 
            style={{ width: `${progress}%` }}
          ></div>
        </div>

        <audio
          ref={audioRef}
          src={set.audioFile}
          onTimeUpdate={handleTimeUpdate}
          onEnded={() => setPlaying(false)}
        />
      </div>

      <div className="p-4">
        <div className="flex items-start justify-between">
          <div className="flex-1 min-w-0">
            <Link href={`/set/${set._id}`}>
              <h3 className="font-display text-lg font-bold text-white truncate hover:text-green-400 transition">
                {set.title}
              </h3>
            </Link>
            <Link href={`/profile/${set.userId?._id}`}>
              <p className="text-sm text-gray-400 hover:text-green-400 transition">
                @{set.userId?.displayName || 'Usuário'}
              </p>
            </Link>
            <p className="text-xs text-gray-500 mt-1 flex items-center gap-2">
              <span>{set.genre}</span>
              <span className="w-1 h-1 bg-gray-600 rounded-full"></span>
              <span>{set.tags?.join(', ')}</span>
            </p>
          </div>
          <div className="flex items-center gap-1 ml-2">
            <button onClick={handleLike} className={`p-1.5 rounded-full transition ${liked ? 'text-green-600 bg-green-600/10' : 'text-gray-400 hover:text-green-400 hover:bg-green-600/10'}`}>
              <Heart size={18} fill={liked ? '#22c55e' : 'none'} />
            </button>
            <span className="text-xs text-gray-400">{likes}</span>
          </div>
        </div>

        <div className="flex justify-between items-center mt-3 pt-3 border-t border-gray-800">
          <div className="flex items-center gap-4">
            <button className="text-gray-400 hover:text-green-400 transition flex items-center gap-1 text-xs">
              <MessageCircle size={16} /> {set.comments?.length || 0}
            </button>
            <button 
              onClick={() => navigator.clipboard.writeText(`${window.location.origin}/set/${set._id}`)}
              className="text-gray-400 hover:text-green-400 transition"
            >
              <Share2 size={16} />
            </button>
          </div>
          <div className="text-xs text-gray-500">
            {set.plays || 0} plays
          </div>
        </div>
      </div>
    </div>
  );
}
