// Verifica se o token JWT é válido
const verifyToken = async (req, res, next) => {
  const token = req.headers.authorization?.split(' ')[1];
  if (!token) return res.status(401).json({ error: 'Token não fornecido' });

  try {
    const decoded = await auth.verifyIdToken(token);
    req.user = decoded; // uid, email, etc.
    
    // Sincroniza/atualiza o usuário no banco de dados
    let dbUser = await User.findOne({ uid: decoded.uid });
    if (!dbUser) {
      dbUser = new User({
        uid: decoded.uid,
        email: decoded.email,
        displayName: decoded.name || 'Usuário',
        photoURL: decoded.picture || '/default-avatar.png',
        // Se for o admin oficial, já configura aqui
        isAdmin: decoded.email === 'purgatoriounder@gmail.com',
        isOfficial: decoded.email === 'purgatoriounder@gmail.com',
      });
      await dbUser.save();
    } else {
      // Atualiza se mudou
      if (decoded.email === 'purgatoriounder@gmail.com') {
        dbUser.isAdmin = true;
        dbUser.isOfficial = true;
        await dbUser.save();
      }
    }
    req.dbUser = dbUser; // Guarda o ObjectId e dados adicionais
    next();
  } catch (err) {
    return res.status(403).json({ error: 'Token inválido' });
  }
};

// Verifica se é admin (deve ser usado após verifyToken)
const isAdmin = (req, res, next) => {
  if (!req.dbUser || !req.dbUser.isAdmin) {
    return res.status(403).json({ error: 'Acesso administrativo negado' });
  }
  next();
};

module.exports = { verifyToken, isAdmin };
const multer = require('multer');
const { GridFsStorage } = require('multer-gridfs-storage');
const crypto = require('crypto');
const path = require('path');

const storage = new GridFsStorage({
  url: process.env.MONGO_URI,
  file: (req, file) => {
    return new Promise((resolve, reject) => {
      crypto.randomBytes(16, (err, buf) => {
        if (err) return reject(err);
        const filename = buf.toString('hex') + path.extname(file.originalname);
        resolve({
          filename: filename,
          bucketName: 'uploads',
        });
      });
    });
  },
});

const upload = multer({ 
  storage,
  limits: { fileSize: 1024 * 1024 * 500 } // 500MB para sets longos
});

module.exports = upload;
