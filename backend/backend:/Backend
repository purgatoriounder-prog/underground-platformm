const express = require('express');
const router = express.Router();
const upload = require('../middleware/upload');
const { verifyToken } = require('../middleware/auth');
const Set = require('../models/Set');
const User = require('../models/User');
const { getGridFSBucket } = require('../config/mongodb');

// FEED de sets
router.get('/feed', async (req, res) => {
  try {
    const sets = await Set.find({ isApproved: true })
                          .populate('userId', 'displayName photoURL isOfficial')
                          .sort({ createdAt: -1 })
                          .limit(20);
    res.json(sets);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

// Detalhes de um set
router.get('/:id', async (req, res) => {
  try {
    const set = await Set.findById(req.params.id)
                         .populate('userId', 'displayName photoURL isOfficial')
                         .populate({
                           path: 'comments',
                           populate: { path: 'userId', select: 'displayName photoURL' }
                         });
    if (!set) return res.status(404).json({ error: 'Set não encontrado' });
    res.json(set);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

// Upload de set (protegido)
router.post('/upload', verifyToken, upload.fields([
  { name: 'audio', maxCount: 1 },
  { name: 'cover', maxCount: 1 },
  { name: 'video', maxCount: 1 }
]), async (req, res) => {
  try {
    const { title, description, genre, tags } = req.body;
    const user = req.dbUser;

    if (!req.files['audio']) {
      return res.status(400).json({ error: 'Arquivo de áudio é obrigatório' });
    }

    const audioFile = req.files['audio'][0].filename;
    const coverFile = req.files['cover'] ? req.files['cover'][0].filename : null;
    const videoFile = req.files['video'] ? req.files['video'][0].filename : null;

    const newSet = new Set({
      userId: user._id,
      title,
      description,
      genre,
      tags: tags ? tags.split(',').map(t => t.trim()) : [],
      coverImage: coverFile ? `/api/files/${coverFile}` : null,
      audioFile: `/api/files/${audioFile}`,
      videoFile: videoFile ? `/api/files/${videoFile}` : null,
    });

    await newSet.save();
    
    // Atualiza estatísticas do usuário
    user.stats.totalSets += 1;
    await user.save();

    res.status(201).json(newSet);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

// Servir arquivos do GridFS
router.get('/files/:filename', async (req, res) => {
  try {
    const bucket = getGridFSBucket();
    const downloadStream = bucket.openDownloadStreamByName(req.params.filename);
    downloadStream.on('error', () => res.status(404).json({ error: 'Arquivo não encontrado' }));
    downloadStream.pipe(res);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

// Curtir / Descurtir
router.post('/:id/like', verifyToken, async (req, res) => {
  try {
    const set = await Set.findById(req.params.id);
    if (!set) return res.status(404).json({ error: 'Set não encontrado' });

    const userId = req.dbUser._id;
    const index = set.likes.indexOf(userId);
    
    if (index > -1) {
      set.likes.splice(index, 1);
    } else {
      set.likes.push(userId);
    }
    await set.save();
    res.json({ likes: set.likes.length });
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

