const express = require('express');
const router = express.Router();
const { verifyToken } = require('../middleware/auth');
const Comment = require('../models/Comment');
const Set = require('../models/Set');

// Adicionar comentário
router.post('/:setId', verifyToken, async (req, res) => {
  try {
    const { text } = req.body;
    const set = await Set.findById(req.params.setId);
    if (!set) return res.status(404).json({ error: 'Set não encontrado' });

    const comment = new Comment({
      set: set._id,
      userId: req.dbUser._id,
      text,
    });
    await comment.save();

    set.comments.push(comment._id);
    await set.save();

    // Popula o usuário para retornar
    await comment.populate('userId', 'displayName photoURL');
    res.status(201).json(comment);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

// Responder comentário
router.post('/:commentId/reply', verifyToken, async (req, res) => {
  try {
    const { text } = req.body;
    const parentComment = await Comment.findById(req.params.commentId);
    if (!parentComment) return res.status(404).json({ error: 'Comentário não encontrado' });

    const reply = new Comment({
      set: parentComment.set,
      userId: req.dbUser._id,
      text,
    });
    await reply.save();

    parentComment.replies.push(reply._id);
    await parentComment.save();

    await reply.populate('userId', 'displayName photoURL');
    res.status(201).json(reply);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

// Deletar comentário (admin ou dono)
router.delete('/:id', verifyToken, async (req, res) => {
  try {
    const comment = await Comment.findById(req.params.id);
    if (!comment) return res.status(404).json({ error: 'Comentário não encontrado' });
    
    if (comment.userId.toString() !== req.dbUser._id.toString() && !req.dbUser.isAdmin) {
      return res.status(403).json({ error: 'Sem permissão' });
    }

    await Comment.deleteOne({ _id: req.params.id });
    // Remove referência do set
    await Set.updateOne({ _id: comment.set }, { $pull: { comments: comment._id } });
    res.json({ success: true });
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

