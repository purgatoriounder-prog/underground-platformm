# === INSTRUÇÕES ===
# Este arquivo é um exemplo. Copie as seções para .env.backend e .env.frontend (ou use .env.backend e .env.frontend diretamente).
# - backend: salve como .env.backend (usado pelo docker-compose acima)
# - frontend: salve como .env.frontend (usado pelo docker-compose acima)
# NÃO comite chaves privadas (serviceAccountKey.json) ou valores reais em repositórios públicos.

# ---------- BACKEND (.env.backend) ----------
# MongoDB (no Docker Compose o host é "mongo")
MONGO_URI=mongodb://mongo:27017/underground
PORT=5000
# Firebase admin: preferível montar o JSON da chave como arquivo em backend/src/config/serviceAccountKey.json
# Em ambiente Docker, monte o arquivo com volumes e deixe o código usar require('./serviceAccountKey.json')
# GOOGLE_APPLICATION_CREDENTIALS=/app/src/config/serviceAccountKey.json

# Opcional: node environment
NODE_ENV=development

# ---------- FRONTEND (.env.frontend) ----------
# Valores do Firebase (pegar em Firebase Console -> Project settings -> SDK)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_bucket.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Endpoint da API (aponta para o backend dentro do host ou para localhost se rodando localmente)
# Quando usar docker-compose e abrir no navegador host, mantenha http://localhost:5000/api
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# ---------- ADMIN / OPÇÕES (exemplo) ----------
# Email do admin (o middleware isAdmin do projeto atualmente compara o email diretamente)
ADMIN_EMAIL=purgatoriounder@gmail.com

# ---------- NOTAS ----------
# - Para rodar com docker-compose (a partir do diretório raiz do repo):
#     docker-compose up --build
# - Se preferir não executar "npm install" toda vez no container, crie Dockerfiles customizados para backend/frontend e ajuste docker-compose para usar build: .
# - Para produção: remova o comando de dev, crie builds (next build) e sirva a app de forma estática/SSR com um servidor (ex.: nginx ou next start).
